# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Environment / secrets
.env

# Local data: keep `data/` in git via `.gitkeep`, ignore everything else under it
data/*
!data/.gitkeep

# logs/
models/

# Submission outputs (regenerate locally)
submission/*.csv
submission/*.parquet
submission/*.ipynb
submission/model.keras

# OS / editor
.DS_Store
.idea/
.vscode/

# Trained model / embedding artifacts (regenerate locally — do not push to GitHub)
*.keras
*.h5
*.hdf5
*.weights.h5
*.npz
*.npy
*.pkl
*.pickle
*.tflite
*.onnx
*.pb

# BirdNET / agent caches and notebook junk (keep only *.ipynb if you choose to commit them)
# notebooks/birdnet_cache/
# notebooks/**/birdnet_cache/
# notebooks/**/birdnet_cache */
# notebooks/cache/submission_preds/
# notebooks/BirdNet/
# !notebooks/BirdNet/*.ipynb

# Other local notebook experiments (uncomment !.../*.ipynb to track selectively)
# Allow specific paths back in
!logs/
!logs/*.log
!logs/*.txt
!logs/*.json
# Still exclude heavy trees
logs/eda/
logs/meta_agent/

# Keep benchmark notebooks + small CSV summaries under notebooks/cache/
# (ipynb and *.csv are not ignored)