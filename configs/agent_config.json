{
  "project_name": "apa-birdclef-autonomous-agent",
  "track": "birdclef",
  "random_seed": 42,
  "max_iterations": 5,
  "llm": {
    "provider": "ollama",
    "model": "qwen2.5-coder:3b",
    "temperature": 0.2
  },
  "llm_researcher": {
    "provider": "ollama",
    "model": "deepseek-r1:8b",
    "temperature": 0.6,
    "enabled": true
  },
  "execution": {
    "timeout_seconds": 1800,
    "final_timeout_seconds": null,
    "python_executable": "C:/Users/lasse/Documents/Master Business Analytics Lasse/Advanced Predictive Analytics/APA-MUE-LO-AW-EZ/.venv/Scripts/python.exe"
  },
  "transfer": {
    "require_pretrained_only": true,
    "min_scored_columns": 35,
    "final_epochs_override": 12
  },
  "search": {
    "cheap": {
      "max_samples": 2000,
      "epochs": 3,
      "val_split": 0.2
    },
    "medium": {
      "max_samples": 10000,
      "epochs": 15,
      "val_split": 0.2
    },
    "final": {
      "max_samples": null,
      "epochs": 15,
      "val_split": 0.1
    },
    "linear_budget": 0,
    "random_budget": 50,
    "phase2": {
      "random_experiments": 5,
      "focused_experiments": 5,
      "tweak_experiments": 5,
      "augmentation_tweak_experiments": 8,
      "ai_free_experiments": 10,
      "final_tweak_experiments": 10,
      "top_results_keep": 2
    },
    "cnn_exploration": {
      "enabled": true
    },
    "transfer_exploration": {
      "enabled": true,
      "max_iterations": 10,
      "interactive_pick_final": false
    },
    "medium_stage": {
      "enabled": false,
      "total_runs": 4,
      "promoted_runs": 4,
      "max_attempts_per_model": 1,
      "resume_from_saved_phase2": false
    },
    "reality_gate": {
      "enabled": false,
      "use_all_candidates": true,
      "top_k": 5,
      "max_samples": 10000,
      "epochs": 15,
      "val_split": 0.2,
      "split_mode": "group_holdout"
    },
    "random_seed": 42
  },
  "eda": {
    "enabled": true
  },
  "logging": {
    "log_dir": "logs",
    "save_generated_code": true,
    "save_metrics_json": true,
    "generate_insights": false
  }
}