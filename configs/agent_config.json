{
  "project_name": "apa-birdclef-autonomous-agent",
  "track": "birdclef",
  "random_seed": 42,
  "max_iterations": 2,
  "llm": {
    "provider": "ollama",
    "model": "qwen2.5-coder:7b",
    "temperature": 0.2
  },
  "llm_researcher": {
    "enabled": true,
    "provider": "ollama",
    "model": "deepseek-r1:8b",
    "temperature": 0.6
  },
  "researcher": {
    "model": "deepseek-r1:8b",
    "temperature": 0.6
  },
  "execution": {
    "timeout_seconds": 1800,
    "final_timeout_seconds": null,
    "python_executable": "python3"
  },
  "transfer": {
    "require_pretrained_only": true,
    "min_scored_columns": 35,
    "final_epochs_override": 12
  },
  "search": {
    "cheap": {
      "max_samples": 2000,
      "epochs": 3,
      "val_split": 0.2
    },
    "medium": {
      "max_samples": 10000,
      "epochs": 15,
      "val_split": 0.2
    },
    "final": {
      "max_samples": null,
      "epochs": 15,
      "val_split": 0.1
    },
    "linear_budget": 0,
    "random_budget": 50,
    "phase2": {
      "random_experiments": 5,
      "focused_experiments": 5,
      "tweak_experiments": 5,
      "augmentation_tweak_experiments": 8,
      "ai_free_experiments": 10,
      "final_tweak_experiments": 10,
      "top_results_keep": 2
    },
    "cnn_exploration": {
      "enabled": false
    },
    "transfer_exploration": {
      "enabled": true,
      "max_iterations": 2,
      "interactive_pick_final": false
    },
    "medium_stage": {
      "enabled": false,
      "total_runs": 4,
      "promoted_runs": 4,
      "max_attempts_per_model": 1,
      "resume_from_saved_phase2": false
    },
    "reality_gate": {
      "enabled": false,
      "use_all_candidates": true,
      "top_k": 5,
      "max_samples": 10000,
      "epochs": 15,
      "val_split": 0.2,
      "split_mode": "group_holdout"
    },
    "random_seed": 42,
    "skip_final_training": true
  },
  "logging": {
    "log_dir": "logs",
    "save_generated_code": true,
    "save_metrics_json": true,
    "generate_insights": false
  },
  "meta_agent": {
    "pipeline": "staged_1a",
    "primary_metric": "macro_average_precision",
    "run_eda": false,
    "aug_baselines": ["light", "medium", "high"],
    "arch_search_iterations_per_aug": null,
    "arch_search_cnn_max_samples": 2000,
    "arch_search_head_train_max_samples": 2000,
    "arch_search_embed_sample_frac": 0.5,
    "arch_search_embed_max_samples": null,
    "force_rebuild_embed_cache": false,
    "cnn_iterations": 0,
    "birdnet_iterations": 0,
    "perch_iterations": 30,
    "ensemble_iterations": 0
  },
  "perch": {
    "onnx_dataset": "rishikeshjani/perch-onnx-for-birdclef-2026",
    "perch_labels_model": "google/bird-vocalization-classifier/tensorFlow2/perch_v2_cpu",
    "max_train_samples": null,
    "embed_batch_size": 16,
    "head_train_max_samples": 2000,
    "force_rebuild_cache": false,
    "skip_final_retrain": true
  },
  "final_retrain": {
    "enabled": false
  }
}