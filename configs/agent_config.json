{
  "project_name": "apa-birdclef-autonomous-agent",
  "track": "birdclef",
  "random_seed": 42,
  "llm": {
    "provider": "ollama",
    "model": "gemma4",
    "temperature": 0.2
  },
  "execution": {
    "timeout_seconds": 1800,
    "final_timeout_seconds": null,
    "python_executable": "python3"
  },
  "search": {
    "cheap": {
      "max_samples": 300,
      "epochs": 3
    },
    "medium": {
      "max_samples": 2000,
      "epochs": 10
    },
    "final": {
      "max_samples": null,
      "epochs": 20
    },
    "linear_budget": 75,
    "random_budget": 50,
    "random_seed": 42
  },
  "logging": {
    "log_dir": "logs",
    "save_generated_code": true,
    "save_metrics_json": true
  }
}