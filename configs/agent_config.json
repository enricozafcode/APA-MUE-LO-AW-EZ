{
  "project_name": "apa-birdclef-autonomous-agent",
  "track": "birdclef",
  "random_seed": 42,
  "max_iterations": 5,
  "llm": {
    "provider": "ollama",
    "model": "qwen2.5-coder:7b",
    "temperature": 0.2,
    "timeout_seconds": 600
  },
  "llm_researcher": {
    "enabled": true,
    "provider": "ollama",
    "model": "qwen2.5-coder:7b",
    "temperature": 0.2
  },
  "researcher": {
    "model": "qwen2.5-coder:7b",
    "temperature": 0.2,
    "timeout_seconds": 600,
    "stream_debug": false,
    "batch_size": 2
  },
  "execution": {
    "timeout_seconds": 1800,
    "final_timeout_seconds": null,
    "python_executable": "python3"
  },
  "transfer": {
    "require_pretrained_only": true,
    "min_scored_columns": 35,
    "final_epochs_override": 12
  },
  "search": {
    "cheap": {
      "max_samples": 1500,
      "epochs": 3,
      "val_split": 0.2
    },
    "medium": {
      "max_samples": 1500,
      "epochs": 5,
      "val_split": 0.2
    },
    "final": {
      "max_samples": null,
      "epochs": 12,
      "val_split": 0.0
    },
    "linear_budget": 0,
    "random_budget": 0,
    "phase2": {
      "random_experiments": 5,
      "focused_experiments": 5,
      "tweak_experiments": 5,
      "augmentation_tweak_experiments": 10,
      "ai_free_experiments": 10,
      "final_tweak_experiments": 10,
      "top_results_keep": 2
    },
    "cnn_exploration": {
      "enabled": false
    },
    "transfer_exploration": {
      "enabled": true,
      "max_iterations": 2,
      "interactive_pick_final": false
    },
    "medium_stage": {
      "enabled": false,
      "total_runs": 4,
      "promoted_runs": 4,
      "max_attempts_per_model": 1,
      "resume_from_saved_phase2": false
    },
    "reality_gate": {
      "enabled": false,
      "use_all_candidates": true,
      "top_k": 5,
      "max_samples": 50,
      "epochs": 2,
      "val_split": 0.2,
      "split_mode": "group_holdout"
    },
    "random_seed": 42,
    "skip_final_training": true
  },
  "logging": {
    "log_dir": "logs",
    "save_generated_code": true,
    "save_metrics_json": true,
    "generate_insights": false
  },
  "meta_agent": {
    "pipeline": "staged_tournament",
    "track_order": ["cnn"],
    "excluded_tracks": ["birdnet", "perch"],
    "tournament": {
      "enabled": true,
      "auto_finalize": true
    },
    "skip_completed_stages": false,
    "primary_metric": "macro_average_precision",
    "run_eda": false,
    "aug_baselines": ["high"],
    "arch_search_iterations_per_aug": 5,
    "focal_clip_seed": 42,
    "arch_search_cnn_max_samples": 1500,
    "arch_search_head_train_max_samples": 1500,
    "arch_search_embed_sample_frac": 1.0,
    "arch_search_embed_max_samples": 1500,
    "force_rebuild_embed_cache": false,
    "cnn_iterations": 5,
    "cnn_staged": true,
    "birdnet_iterations": 0,
    "perch_iterations": 0,
    "ensemble_iterations": 0,
    "cnn_stage_1b": {
      "enabled": true,
      "top_k_models": 1,
      "experiments_per_researcher_call": 2,
      "initial_iterations": 5,
      "bonus_iterations_on_improve": 2,
      "max_iterations_per_model": 7
    },
    "cnn_stage_1c": {
      "enabled": true,
      "mode": "both",
      "planner_rounds": 5,
      "experiments_per_round": 2,
      "aug_presets": ["high"],
      "include_winner_aug_baseline": true,
      "include_preset_baselines": false,
      "include_champion_reference": true,
      "head_train_samples": 1500,
      "researcher_format_json": true,
      "researcher_num_predict": 4096
    },
    "cnn_stage_1d": {
      "enabled": true,
      "epochs": 12,
      "max_samples": null,
      "val_split": 0.0,
      "rebuild_focal_cache": true,
      "copy_to_submission": true,
      "final_timeout_seconds": 7200
    },
    "birdnet_stage_1b": {
      "enabled": false,
      "top_k_models": 1,
      "experiments_per_researcher_call": 1,
      "initial_iterations": 1,
      "bonus_iterations_on_improve": 1,
      "max_iterations_per_model": 2
    },
    "birdnet_stage_1c": {
      "enabled": false,
      "mode": "presets",
      "aug_presets": ["medium"],
      "include_winner_aug_baseline": true
    },
    "birdnet_stage_1d": {
      "enabled": false,
      "embed_sample_frac": 1.0,
      "rebuild_full_train_cache": false,
      "copy_to_submission": true,
      "final_timeout_seconds": 7200
    },
    "birdnet_stage_1e": {
      "enabled": false,
      "max_soundscape_files": 5,
      "top1_threshold": 0.55,
      "runnerup_max": 0.35,
      "pseudo_label_weight": 0.8,
      "sample_weight_supervised": 1.0,
      "sample_weight_labeled_val": 1.0,
      "include_labeled_val_in_refine": true,
      "sample_weight_pseudo": 0.5,
      "fine_tune_epochs": 2,
      "fine_tune_lr": 0.0002,
      "val_split": 0.1,
      "rebuild_pseudo_cache": false,
      "refine_timeout_seconds": 7200,
      "copy_to_submission": true
    },
    "cnn_stage_1e": {
      "enabled": true,
      "skip_fine_tune_without_pseudo": true,
      "max_soundscape_files": null,
      "max_pseudo_windows": null,
      "heartbeat_every": 10,
      "top1_threshold": 0.55,
      "runnerup_max": 0.35,
      "pseudo_label_weight": 0.8,
      "sample_weight_supervised": 1.0,
      "sample_weight_pseudo": 0.5,
      "fine_tune_epochs": 5,
      "fine_tune_lr": 0.0002,
      "rebuild_pseudo_cache": true,
      "refine_timeout_seconds": 7200,
      "copy_to_submission": true
    },
    "stage_1b": {
      "enabled": false,
      "top_k_models": 1,
      "experiments_per_researcher_call": 1,
      "initial_iterations": 1,
      "bonus_iterations_on_improve": 1,
      "max_iterations_per_model": 2
    },
    "stage_1c": {
      "enabled": false,
      "mode": "presets",
      "planner_rounds": 1,
      "experiments_per_round": 1,
      "aug_presets": ["medium"],
      "include_preset_baselines": true,
      "include_winner_aug_baseline": true,
      "head_train_samples": 50,
      "embed_subset_only": true,
      "force_rebuild_embed_cache": false,
      "researcher_timeout_seconds": 600,
      "stream_debug": false
    },
    "stage_1d": {
      "enabled": false,
      "embed_sample_frac": 1.0,
      "rebuild_full_train_cache": false,
      "copy_to_submission": true,
      "final_timeout_seconds": 7200
    },
    "stage_1e": {
      "enabled": false,
      "max_soundscape_files": 5,
      "top1_threshold": 0.55,
      "runnerup_max": 0.35,
      "pseudo_label_weight": 0.8,
      "sample_weight_supervised": 1.0,
      "sample_weight_labeled_val": 1.0,
      "include_labeled_val_in_refine": true,
      "sample_weight_pseudo": 0.5,
      "fine_tune_epochs": 2,
      "fine_tune_lr": 0.0002,
      "val_split": 0.1,
      "file_batch_size": 16,
      "heartbeat_every": 5,
      "partial_save_every": 500,
      "rebuild_pseudo_cache": false,
      "refine_timeout_seconds": 7200,
      "copy_to_submission": true
    }
  },
  "perch": {
    "use_llm_memory_summaries": false,
    "onnx_dataset": "rishikeshjani/perch-onnx-for-birdclef-2026",
    "perch_labels_model": "google/bird-vocalization-classifier/tensorFlow2/perch_v2_cpu",
    "max_train_samples": 50,
    "embed_batch_size": 16,
    "head_train_max_samples": 50,
    "force_rebuild_cache": false,
    "skip_final_retrain": true
  },
  "final_retrain": {
    "enabled": false
  }
}