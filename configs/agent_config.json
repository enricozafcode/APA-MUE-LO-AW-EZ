{
  "project_name": "apa-birdclef-autonomous-agent",
  "track": "birdclef",
  "random_seed": 42,
  "max_iterations": 5,
  "llm": {
    "provider": "ollama",
    "model": "qwen2.5-coder:7b",
    "temperature": 0.2,
    "timeout_seconds": 600
  },
  "llm_researcher": {
    "provider": "ollama",
    "model": "qwen2.5-coder:7b",
    "temperature": 0.2
  },
  "researcher": {
    "model": "qwen2.5-coder:7b",
    "temperature": 0.2,
    "timeout_seconds": 600,
    "stream_debug": false,
    "batch_size": 2
  },
  "execution": {
    "timeout_seconds": 1800,
    "final_timeout_seconds": null,
    "python_executable": "python3"
  },
  "search": {
    "cheap": {
      "max_samples": 1500,
      "epochs": 3,
      "patience": 3,
      "val_split": 0.2,
      "n_mels": 64,
      "n_frames": 128
    },
    "final": {
      "max_samples": null,
      "epochs": 12,
      "val_split": 0.0
    },
    "random_seed": 42
  },
  "logging": {
    "log_dir": "logs",
    "save_generated_code": true,
    "save_metrics_json": true,
    "generate_insights": false
  },
  "meta_agent": {
    "pipeline": "staged_tournament",
    "track_order": ["cnn", "perch"],
    "tournament": {
      "enabled": true,
      "auto_finalize": true,
      "fallback_to_1b_on_1c_miss": true
    },
    "skip_completed_stages": false,
    "compact_terminal": true,
    "primary_metric": "macro_average_precision",
    "researcher_history_max_runs": null,
    "experiment_tracker": {
      "enabled": true,
      "timeline_json": "logs/meta_agent/experiment_timeline.json",
      "plots_dir": "logs/meta_agent/experiment_plots",
      "live_window": 5,
      "write_pipeline_plot": true,
      "terminal_notice": false
    },
    "bundle_kaggle_dataset": true,
    "run_eda": true,
    "eda": {
      "use_llm_codegen": true,
      "use_iterative_eda": true,
      "exploration_iterations": 10,
      "fixes_per_iteration": 5,
      "staged_codegen": false,
      "max_codegen_attempts": 5,
      "script_timeout_seconds": 600,
      "llm_timeout_seconds": 600,
      "max_codegen_wall_seconds": 7200,
      "brief_max_chars": 600,
      "use_cached_brief": true,
      "force_rebuild": false
    },
    "aug_baselines": ["high"],
    "focal_clip_seed": 42,
    "arch_search_cnn_max_samples": 1500,
    "arch_search_head_train_max_samples": 1500,
    "arch_search_embed_sample_frac": 1.0,
    "arch_search_embed_max_samples": 1500,
    "force_rebuild_embed_cache": false,
    "cnn_search_arch_limits": {
      "max_conv_filters": 64,
      "min_pooling_layers": 2,
      "max_params": 1500000
    },
    "arch_search_head_epochs": 3,
    "arch_search_head_patience": 3,
    "cnn_iterations": 1,
    "perch_iterations": 5,
    "cnn_staged": true,
    "cnn_stage_1b": {
      "enabled": true,
      "top_k_models": 1,
      "experiments_per_researcher_call": 2,
      "initial_iterations": 3,
      "bonus_iterations_on_improve": 1,
      "max_iterations_per_model": 5
    },
    "cnn_stage_1c": {
      "enabled": true,
      "mode": "both",
      "planner_rounds": 3,
      "planner_rounds_on_top_of_resume": true,
      "experiments_per_round": 1,
      "aug_presets": ["high"],
      "include_winner_aug_baseline": true,
      "include_preset_baselines": true,
      "include_champion_reference": true,
      "head_train_samples": 1500,
      "researcher_format_json": true,
      "researcher_num_predict": 4096
    },
    "cnn_stage_1d": {
      "enabled": true,
      "epochs": 12,
      "max_samples": null,
      "val_split": 0.0,
      "rebuild_focal_cache": true,
      "copy_to_submission": true,
      "final_timeout_seconds": 14400
    },
    "cnn_stage_1e": {
      "enabled": true,
      "skip_fine_tune_without_pseudo": true,
      "max_soundscape_files": null,
      "max_pseudo_windows": null,
      "heartbeat_every": 10,
      "top1_threshold": 0.55,
      "runnerup_max": 0.35,
      "pseudo_label_weight": 0.8,
      "sample_weight_supervised": 1.0,
      "sample_weight_pseudo": 0.5,
      "fine_tune_epochs": 5,
      "fine_tune_lr": 0.0002,
      "rebuild_pseudo_cache": true,
      "refine_timeout_seconds": 7200,
      "copy_to_submission": true
    },
    "stage_1b": {
      "enabled": true,
      "top_k_models": 1,
      "experiments_per_researcher_call": 2,
      "initial_iterations": 5,
      "bonus_iterations_on_improve": 2,
      "max_iterations_per_model": 7
    },
    "stage_1c": {
      "enabled": true,
      "mode": "both",
      "planner_rounds": 3,
      "planner_rounds_on_top_of_resume": true,
      "experiments_per_round": 2,
      "aug_presets": ["high"],
      "include_preset_baselines": true,
      "include_winner_aug_baseline": true,
      "include_champion_reference": true,
      "head_train_samples": 1500,
      "embed_subset_only": true,
      "force_rebuild_embed_cache": false,
      "resume_partial_trials": true,
      "researcher_timeout_seconds": 600,
      "researcher_format_json": true,
      "researcher_num_predict": 4096,
      "stream_debug": false
    },
    "stage_1d": {
      "enabled": true,
      "embed_sample_frac": 1.0,
      "max_train_samples": null,
      "rebuild_full_train_cache": true,
      "score_after_retrain": true,
      "copy_to_submission": true,
      "bundle_kaggle_dataset": true,
      "final_timeout_seconds": 7200
    },
    "stage_1e": {
      "enabled": true,
      "max_soundscape_files": null,
      "max_pseudo_windows": null,
      "top1_threshold": 0.55,
      "runnerup_max": 0.35,
      "pseudo_label_weight": 0.8,
      "sample_weight_supervised": 1.0,
      "sample_weight_labeled_val": 1.0,
      "include_labeled_val_in_refine": true,
      "sample_weight_pseudo": 0.5,
      "fine_tune_epochs": 5,
      "fine_tune_lr": 0.0002,
      "val_split": 0.0,
      "file_batch_size": 16,
      "heartbeat_every": 10,
      "partial_save_every": 500,
      "rebuild_pseudo_cache": true,
      "refine_timeout_seconds": 7200,
      "copy_to_submission": true,
      "bundle_kaggle_dataset": true
    }
  },
  "perch": {
    "use_llm_memory_summaries": false,
    "onnx_dataset": "rishikeshjani/perch-onnx-for-birdclef-2026",
    "perch_labels_model": "google/bird-vocalization-classifier/tensorFlow2/perch_v2_cpu",
    "max_train_samples": 1500,
    "embed_batch_size": 16,
    "head_train_max_samples": 1500,
    "force_rebuild_cache": false,
    "skip_final_retrain": true
  }
}
