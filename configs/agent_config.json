{
  "project_name": "apa-birdclef-autonomous-agent",
  "track": "birdclef",
  "max_iterations": 10,
  "max_failures_before_stop": 3,
  "time_budget_minutes": 180,
  "random_seed": 42,
  "llm": {
    "provider": "ollama", 
    "model": "deepseek-r1:8b",
    "temperature": 0.2
  },
  "execution": {
    "timeout_seconds": 1800,
    "python_executable": "python3"
  },
  "logging": {
    "log_dir": "logs",
    "save_generated_code": true,
    "save_metrics_json": true
  },
  "augmentation": {
    "audio": {
      "time_stretch":    { "enabled": true,  "probability": 0.5, "rate_min": 0.9, "rate_max": 1.1 },
      "pitch_shift":     { "enabled": false, "probability": 0.3, "steps_min": -2, "steps_max": 2 },
      "noise_injection": { "enabled": true,  "probability": 0.4, "noise_level": 0.005 },
      "time_shift":      { "enabled": false, "probability": 0.5, "shift_max_fraction": 0.5 }
    },
    "spectrogram": {
      "time_mask": { "enabled": true,  "max_mask_size": 40, "num_masks": 1 },
      "freq_mask": { "enabled": true,  "max_mask_size": 20, "num_masks": 1 },
      "mixup":     { "enabled": false, "alpha": 0.4 },
      "cutmix":    { "enabled": false, "alpha": 1.0 }
    }
  }
}
