# Copy this file to .env and adjust values for your machine.

# LLM provider: ollama | openai_compatible
LLM_PROVIDER=ollama

# Ollama defaults
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder

# Optional OpenAI-compatible endpoint (LM Studio / llama.cpp server / remote VM)
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=replace-me-if-needed
OPENAI_MODEL=qwen3-coder

# Project paths (relative to repository root)
DATA_DIR=data
LOG_DIR=logs
SUBMISSION_DIR=submission
